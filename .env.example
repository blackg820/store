# ==================================================================
# Storify - SaaS Multi-Store Order Management
# Production Environment Variables
# ==================================================================

# ----- Database (choose one) -----
# Neon / Supabase / Amazon Aurora PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/storify

# ----- Authentication -----
# Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ----- Bunny.net CDN (Media Storage) -----
# Create Storage Zone at https://bunny.net/
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_API_KEY=your-bunny-storage-api-key
BUNNY_PULL_ZONE=your-pull-zone.b-cdn.net
BUNNY_REGION=storage.bunnycdn.com

# ----- Telegram Bot -----
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEF_your_bot_token_here
TELEGRAM_BOT_USERNAME=StorifyBot

# ----- Cron Security -----
# Vercel Cron jobs secret header
CRON_SECRET=your-cron-secret-random-string

# ----- Optional: Upstash Redis (Rate Limiting) -----
# Recommended for production to replace in-memory rate limiter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Application -----
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_USE_SUBDOMAINS=false
NEXT_PUBLIC_ROOT_DOMAIN=your-domain.com
NODE_ENV=production
